<mxfile host="app.diagrams.net">
  <diagram id="strategy-steps" name="Стратегия развития">
    <mxGraphModel background="#FFFFFF" dx="863" dy="541" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="900" math="0" shadow="0" defaultFontColor="#000000">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=#FFFFFF;fontColor=#000000;align=center;verticalAlign=middle;fontStyle=1;fontSize=16;" value="Шаги для формирования стратегии. Планы развития бизнеса&lt;br&gt;&lt;font style=&quot;font-size: 12px; color: #000000;&quot;&gt;Банк «Стандарт»&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="1200" x="600" y="10" as="geometry" />
        </mxCell>
        <mxCell id="n1" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#64B5F6;strokeColor=#1565C0;fontColor=#000000;strokeWidth=2;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;" value="1" vertex="1">
          <mxGeometry height="40" width="40" x="255" y="70" as="geometry" />
        </mxCell>
        <mxCell id="h1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64B5F6;strokeColor=#1565C0;fontColor=#000000;strokeWidth=2;fontStyle=0;fontSize=12;align=center;verticalAlign=middle;" value="Определение цели&lt;br&gt;для компании" vertex="1">
          <mxGeometry height="70" width="470" x="40" y="120" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#78909C;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontColor=#000000" value="&lt;b&gt;Бизнес-стратегия&lt;/b&gt;&lt;br&gt;&lt;br&gt;Развивать &lt;b&gt;сайт&lt;/b&gt; и &lt;b&gt;интернет-банк&lt;/b&gt;, чтобы предоставлять больше продуктов онлайн.&lt;br&gt;&lt;br&gt;Упор на &lt;b&gt;депозиты, накопительные счета и кредиты&lt;/b&gt; — ставки выгоднее конкурентов.&lt;br&gt;&lt;br&gt;Две ключевые инициативы:&lt;br&gt;• ИБ — открытие депозитов и подача кредитной заявки&lt;br&gt;• Сайт — заявка на депозит (кол-центр), в перспективе — заявка на кредит" vertex="1">
          <mxGeometry height="200" width="470" x="40" y="210" as="geometry" />
        </mxCell>
        <mxCell id="n2" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#64B5F6;strokeColor=#1565C0;fontColor=#000000;strokeWidth=2;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;" value="2" vertex="1">
          <mxGeometry height="40" width="40" x="835" y="70" as="geometry" />
        </mxCell>
        <mxCell id="h2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64B5F6;strokeColor=#1565C0;fontColor=#000000;strokeWidth=2;fontSize=12;align=center;verticalAlign=middle;" value="Описание текущей и целевой&lt;br&gt;структуры бизнеса" vertex="1">
          <mxGeometry height="70" width="470" x="620" y="120" as="geometry" />
        </mxCell>
        <mxCell id="s2a" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#78909C;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fontColor=#000000" value="&lt;b&gt;Схемы организационной структуры&lt;/b&gt;&lt;br&gt;AS-IS: фронт-офис в 50 отделениях (500), бэк-офис депозитов и кредитов (50+50), ИТ, кол-центры&lt;br&gt;TO-BE: сокращение участия бэк-офиса в открытии депозитов" vertex="1">
          <mxGeometry height="95" width="470" x="620" y="210" as="geometry" />
        </mxCell>
        <mxCell id="s2b" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#78909C;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fontColor=#000000" value="&lt;b&gt;Карты бизнес-процессов&lt;/b&gt;&lt;br&gt;&lt;b&gt;Депозиты AS-IS:&lt;/b&gt; открытие только в отделении, фронт-офис + бэк-офис&lt;br&gt;&lt;b&gt;Депозиты TO-BE:&lt;/b&gt; полностью в интернет-банке; в отделении — только фронт-офис&lt;br&gt;&lt;b&gt;Кредиты TO-BE:&lt;/b&gt; предодобренное предложение в ИБ → быстрая заявка → решение за 1 день" vertex="1">
          <mxGeometry height="110" width="470" x="620" y="315" as="geometry" />
        </mxCell>
        <mxCell id="s2c" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#78909C;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fontColor=#000000" value="&lt;b&gt;Карты бизнес-возможностей&lt;/b&gt;&lt;br&gt;• Онлайн-заявка и открытие депозита / накопительного счёта (ИБ)&lt;br&gt;• Подача кредитной заявки с предпросмотром одобрения (ИБ)&lt;br&gt;• Заявка на депозит с сайта + обработка кол-центром&lt;br&gt;• Заявка на кредит с сайта (данные из БКИ)" vertex="1">
          <mxGeometry height="100" width="470" x="620" y="435" as="geometry" />
        </mxCell>
        <mxCell id="s2d" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#78909C;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fontColor=#000000" value="&lt;b&gt;Бизнес-модели&lt;/b&gt;&lt;br&gt;Цифровой канал (сайт → кол-центр → продукт) + самообслуживание в интернет-банке&lt;br&gt;Омниканальность: сайт, ИБ, отделение (без бэк-офиса на финальном этапе)" vertex="1">
          <mxGeometry height="95" width="470" x="620" y="545" as="geometry" />
        </mxCell>
        <mxCell id="n3" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#64B5F6;strokeColor=#1565C0;fontColor=#000000;strokeWidth=2;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;" value="3" vertex="1">
          <mxGeometry height="40" width="40" x="1415" y="70" as="geometry" />
        </mxCell>
        <mxCell id="h3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64B5F6;strokeColor=#1565C0;fontColor=#000000;strokeWidth=2;fontSize=12;align=center;verticalAlign=middle;" value="Описание текущей и целевой&lt;br&gt;архитектуры" vertex="1">
          <mxGeometry height="70" width="470" x="1200" y="120" as="geometry" />
        </mxCell>
        <mxCell id="s3a" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#78909C;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fontColor=#000000" value="&lt;b&gt;Карты IT-ландшафта&lt;/b&gt;&lt;br&gt;&lt;b&gt;Каналы:&lt;/b&gt; публичный сайт, интернет-банк (команды банка и подрядчика)&lt;br&gt;&lt;b&gt;Ядро:&lt;/b&gt; АБС (20 чел.) — учёт депозитов и кредитов&lt;br&gt;&lt;b&gt;Поддержка:&lt;/b&gt; кол-центр на платформе подрядчика (200 операторов + 5 сопровождение)&lt;br&gt;&lt;b&gt;Целевое состояние:&lt;/b&gt; сквозная автоматизация открытия депозита без ручного бэк-офиса" vertex="1">
          <mxGeometry height="130" width="470" x="1200" y="210" as="geometry" />
        </mxCell>
        <mxCell id="s3b" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#78909C;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fontColor=#000000" value="&lt;b&gt;Схемы интеграции приложений&lt;/b&gt;&lt;br&gt;• Сайт ↔ CRM/кол-центр (передача заявки на депозит)&lt;br&gt;• Интернет-банк ↔ АБС (депозиты, кредиты, предодобренные предложения)&lt;br&gt;• Интернет-банк / сайт ↔ &lt;b&gt;БКИ&lt;/b&gt; (оценка кредитоспособности неизвестного клиента с сайта)&lt;br&gt;• MVP: онлайн-заявка на депозит → ручная обработка бэк-офисом (старый процесс)" vertex="1">
          <mxGeometry height="140" width="470" x="1200" y="350" as="geometry" />
        </mxCell>
        <mxCell id="n4" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#64B5F6;strokeColor=#1565C0;fontColor=#000000;strokeWidth=2;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;" value="4" vertex="1">
          <mxGeometry height="40" width="40" x="1995" y="70" as="geometry" />
        </mxCell>
        <mxCell id="h4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64B5F6;strokeColor=#1565C0;fontColor=#000000;strokeWidth=2;fontSize=12;align=center;verticalAlign=middle;" value="Планирование изменений" vertex="1">
          <mxGeometry height="70" width="470" x="1780" y="120" as="geometry" />
        </mxCell>
        <mxCell id="s4a" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFD54F;strokeColor=#F57F17;fontColor=#000000;strokeWidth=2;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;Проект MVP — 6 месяцев&lt;/b&gt; (промежуточное состояние)&lt;br&gt;• Клиент оформляет заявку на депозит / накопительный счёт в интернет-банке&lt;br&gt;• Бэк-офис обрабатывает заявки по &lt;b&gt;старому процессу&lt;/b&gt;&lt;br&gt;• Заявка на депозит с сайта → звонок менеджера кол-центра" vertex="1">
          <mxGeometry height="110" width="470" x="1780" y="210" as="geometry" />
        </mxCell>
        <mxCell id="s4b" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontColor=#000000;strokeWidth=2;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;Программа целевого состояния — 12 месяцев&lt;/b&gt; (финальное состояние)&lt;br&gt;• Депозит / накопительный счёт в ИБ — &lt;b&gt;полностью автоматически&lt;/b&gt;, без бэк-офиса&lt;br&gt;• В отделении — только фронт-офис (снижение операционных издержек)&lt;br&gt;• Кредитная заявка в ИБ и на сайте — решение &lt;b&gt;в течение 1 дня&lt;/b&gt; при достаточности данных&lt;br&gt;• Предодобренные предложения в интернет-банке (как у конкурентов)" vertex="1">
          <mxGeometry height="130" width="470" x="1780" y="330" as="geometry" />
        </mxCell>
        <mxCell id="s4c" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#78909C;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fontColor=#000000" value="&lt;b&gt;Проект, программа проектов или продукт&lt;/b&gt;&lt;br&gt;Продуктовые потоки: «Онлайн-депозиты», «Онлайн-кредиты», «Лиды с сайта»" vertex="1">
          <mxGeometry height="60" width="470" x="1780" y="470" as="geometry" />
        </mxCell>
        <mxCell id="arr12" edge="1" parent="1" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;fillColor=#64B5F6;strokeColor=#1565C0;fontColor=#000000;strokeWidth=2;endWidth=12;endSize=6;width=10;" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="520" y="155" as="sourcePoint" />
            <mxPoint x="610" y="155" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arr23" edge="1" parent="1" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;fillColor=#64B5F6;strokeColor=#1565C0;fontColor=#000000;strokeWidth=2;endWidth=12;endSize=6;width=10;" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1100" y="155" as="sourcePoint" />
            <mxPoint x="1190" y="155" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arr34" edge="1" parent="1" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;fillColor=#64B5F6;strokeColor=#1565C0;fontColor=#000000;strokeWidth=2;endWidth=12;endSize=6;width=10;" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1680" y="155" as="sourcePoint" />
            <mxPoint x="1770" y="155" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="goals-box" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64B5F6;strokeColor=#1565C0;fontColor=#000000;strokeWidth=2;fontSize=11;align=center;verticalAlign=middle;" value="&lt;b&gt;Цели бизнеса (зафиксировано)&lt;/b&gt;" vertex="1">
          <mxGeometry height="35" width="2210" x="40" y="680" as="geometry" />
        </mxCell>
        <mxCell id="goals-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFD54F;strokeColor=#F57F17;fontColor=#000000;strokeWidth=2;fontSize=11;align=left;spacingLeft=8;verticalAlign=middle;" value="&lt;b&gt;6 месяцев:&lt;/b&gt; депозит / накопительный счёт в интернет-банке (MVP); бэк-офис — по старому процессу" vertex="1">
          <mxGeometry height="45" width="1080" x="40" y="730" as="geometry" />
        </mxCell>
        <mxCell id="goals-12" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontColor=#000000;strokeWidth=2;fontSize=11;align=left;spacingLeft=8;verticalAlign=middle;" value="&lt;b&gt;12 месяцев:&lt;/b&gt; полная автоматизация депозита в ИБ; в отделении — только фронт-офис; кредитная заявка в ИБ и на сайте — решение за 1 день" vertex="1">
          <mxGeometry height="45" width="1110" x="1140" y="730" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
